# Database (PostgreSQL — e.g. Supabase connection string)
DATABASE_URL="postgresql://user:password@host:5432/outreachos?schema=public"

# Redis (Upstash — use the ioredis-compatible URL)
REDIS_URL="rediss://default:password@host.upstash.io:6380"

# Server
PORT=4000
NODE_ENV=development

# Auth (added in B-003)
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# Stripe (added in B-014)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH=

# Third-party integrations (added in later steps)
# PROXYCURL_API_KEY=
# APOLLO_API_KEY=
# HUNTER_API_KEY=
# ZEROBOUNCE_API_KEY=
# CLAY_API_KEY=
# HEYREACH_API_KEY=
# INSTANTLY_API_KEY=
